# Copy to .env and fill in the sandbox keys you have. Anything left blank
# falls back to a deterministic mock (the "hybrid" integration mode), so the
# whole stack runs end-to-end with zero credentials.

# ---- India: Razorpay (test mode) ----
# Dashboard → Settings → API Keys (use the rzp_test_ key pair)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---- United States: Stripe (test mode) ----
# Dashboard → Developers → API keys (use the sk_test_ secret key)
STRIPE_SECRET_KEY=

# ---- Philippines: PayMongo (test mode) ----
# Dashboard → Developers → API keys (use the sk_test_ secret key)
PAYMONGO_SECRET_KEY=

# ---- AI strategy assessment: Anthropic / Claude ----
# console.anthropic.com → API keys. Powers the live "strategy_check" step.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Sanctions / liabilities screening: trade.gov CSL ----
# Free key at api.data.gov. Powers live sanctions match in "liabilities_check".
# (Domain availability in "ip_check" uses public RDAP and needs no key.)
CSL_API_KEY=

# Connection pool size — keep small (e.g. 2) on serverless/Lambda; use a pooler.
DB_MAX_CONNS=10

# ---- Authentication ----
# JWT signing secret — MUST be a strong random value in any real deployment
# (e.g. `openssl rand -hex 32`). The default is insecure and public.
JWT_SECRET=
# Seeded accounts (created on first startup). Change these for production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
DEMO_USERNAME=demo
DEMO_PASSWORD=demo123

# Set to true to force every step (including live ones) into mock mode.
FORCE_MOCK=false
