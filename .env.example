# Copy to .env and fill in the sandbox keys you have. Anything left blank
# falls back to a deterministic mock (the "hybrid" integration mode), so the
# whole stack runs end-to-end with zero credentials.

# ---- India: Razorpay (test mode) ----
# Dashboard → Settings → API Keys (use the rzp_test_ key pair)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---- United States: Stripe (test mode) ----
# Dashboard → Developers → API keys (use the sk_test_ secret key)
STRIPE_SECRET_KEY=

# ---- Philippines: PayMongo (test mode) ----
# Dashboard → Developers → API keys (use the sk_test_ secret key)
PAYMONGO_SECRET_KEY=

# Set to true to force every step (including payments) into mock mode.
FORCE_MOCK=false
